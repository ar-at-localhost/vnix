{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "./lua/?.lua",
      "./lua/?/init.lua",
      "${env:WEZTERM_LUA_TYPES}/?.lua",
      "${env:WEZTERM_LUA_TYPES}/?/init.lua"
    ]
  },
  "workspace": {
    "library": [
      "${env:WEZTERM_LUA_TYPES}",
      "${env:NVIM_SNACKS_LUA_TYPES}",
      "${env:NVIM_ORGMODE_LUA_TYPES}",
      "${env:VIMRUNTIME}/lua",
      "${3rd}/luv/library",
      "${3rd}/busted/library"
    ]
  },
  "diagnostics": {
    "globals": ["describe", "it", "_G"]
  }
}
